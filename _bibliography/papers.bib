@inproceedings{galim2026draft,
  title        = {Draft-based Approximate Inference for {LLMs}},
  author       = {Galim*, Kevin and Ewer*, Ethan and Kang, Wonjun and Lee, Minjae and Koo, Hyung Il and Lee, Kangwook},
  booktitle    = {International Conference on Learning Representations},
  year         = {2026},
  abbr         = {ICLR},
  arxiv        = {2506.08373},
  abstract     = {We present a unified framework for approximate inference in long-context LLMs using small draft models to predict token and KV-cache importance. We introduce SpecKV, SpecPC, and SpecKV-PC, enabling more accurate KV-cache and prompt compression while preserving the same efficiency gains in memory usage, latency, and throughput.},
  selected     = {true},
  equal_contrib = {true},
  note         = {* Equal contribution},
}

@inproceedings{kang2026parallelbench,
  title        = {{ParallelBench}: Understanding the Trade-offs of Parallel Decoding in Diffusion {LLMs}},
  author       = {Kang*, Wonjun and Galim*, Kevin and Oh*, Seunghyuk and Lee, Minjae and Zeng, Yuchen and Zhang, Shuibai and Hooper, Coleman and Hu, Yuezhou and Koo, Hyung Il and Cho, Nam Ik and others},
  booktitle    = {International Conference on Learning Representations},
  year         = {2026},
  abbr         = {ICLR},
  arxiv        = {2510.04767},
  abstract     = {Analyzes the fundamental limitations of parallel decoding in diffusion LLMs and introduces ParallelBench, the first benchmark designed to measure quality degradation caused by token dependency violations. Reveals key speed–quality trade-offs and highlights the need for new decoding strategies.},
  selected     = {true},
  equal_contrib = {true},
  note         = {* Equal contribution},
}

